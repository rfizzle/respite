# respite — chronometer top/bottom cap (copper ring, redstone core)
size: 32

legend:
  K ink                      # #0a0a0a selective outline
  1 #eb8a5c                  # copper highlight
  2 #c96a43                  # copper
  3 #9c4e2f                  # copper shadow
  4 #7a3a22                  # copper occlusion
  a #b8b8b8                  # smooth stone highlight
  b #9e9e9e                  # smooth stone
  c #808080                  # smooth stone shadow
  d #636363                  # smooth stone occlusion
  N #232838                  # dial recess (night slate)
  n #1a1f2e                  # dial recess deep
  w #46527e                  # recess star speck
  S respite.candleglow-pale  # sun highlight
  s respite.candleglow       # sun body
  t #d99a2b                  # sun shadow
  M respite.moonlight-bright # moon highlight
  m respite.moonlight        # moon body
  u #5a68b8                  # moon shadow
  R #e04635                  # redstone inlay bright
  r #b3271e                  # redstone inlay

