            "com.rfizzle.respite.gametest.TimeLapseGameTest",
            "com.rfizzle.respite.gametest.RestfulSaturationGameTest",
            "com.rfizzle.respite.gametest.WearinessGameTest",
            "com.rfizzle.respite.gametest.WellRestedGameTest",
            "com.rfizzle.respite.gametest.PhantomGameTest",
            "com.rfizzle.respite.gametest.CaffeinatedBrewGameTest",
            "com.rfizzle.respite.gametest.BedrollGameTest",
            "com.rfizzle.respite.gametest.SleepVoteGameTest",
            "com.rfizzle.respite.gametest.RespiteCommandGameTest",
            "com.rfizzle.respite.gametest.AdvancementGameTest",
